# Copy this to .env and fill in your values
# Never commit the actual .env to git!

# App
APP_NAME=NURA API
DEBUG=true
ENVIRONMENT=development

# Database (auto-filled by docker-compose for local dev)
DATABASE_URL=postgresql+asyncpg://nura:nura_pass@localhost:5432/nura_db

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Security
SECRET_KEY=CHANGE_THIS_TO_A_RANDOM_64_CHAR_STRING

# Supabase Auth
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIs...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIs...
# Find this in Supabase dashboard → Settings → API → JWT Secret
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Anthropic AI
ANTHROPIC_API_KEY=sk-ant-api03-...

# WhatsApp / Meta
META_WHATSAPP_VERIFY_TOKEN=nura_wh_verify_token_change_me
META_APP_SECRET=your_meta_app_secret

# M-Pesa (Safaricom Daraja)
MPESA_BASE_URL=https://sandbox.safaricom.co.ke
MPESA_CONSUMER_KEY=your_consumer_key
MPESA_CONSUMER_SECRET=your_consumer_secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919
MPESA_CALLBACK_URL=https://YOUR_DOMAIN/api/v1/webhooks/mpesa/callback

# Sentry (optional)
SENTRY_DSN=
